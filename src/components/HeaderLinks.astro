---
import HeaderLink from "./HeaderLink.astro";
import Icon from "../components/Icon.astro";
import { mdiBriefcase, mdiController, mdiEmail, mdiNewspaper } from "@mdi/js";
import { CONSTS } from "../consts";
---

<HeaderLink href={CONSTS.urls.freelance}>
  <span class="text-stone-100">
    <Icon path={mdiBriefcase} />
  </span>
  <span>Freelance</span>
</HeaderLink>
<HeaderLink href={CONSTS.urls.scree}>
  <span class="text-stone-100">
    <Icon path={mdiController} />
  </span>
  <span>Scree</span>
</HeaderLink>
<HeaderLink href={CONSTS.urls.blog}>
  <span class="text-stone-100">
    <Icon path={mdiNewspaper} />
  </span>
  <span>Blog</span>
</HeaderLink>
<HeaderLink href={CONSTS.urls.contact}>
  <span class="text-stone-100">
    <Icon path={mdiEmail} />
  </span>
  <span>Contact</span>
</HeaderLink>

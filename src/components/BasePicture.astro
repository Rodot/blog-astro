---
import { Picture } from "@astrojs/image/components";
import type { ImageMetadata } from "astro";
import { getImage } from "@astrojs/image";

interface Props {
  filename?: string | undefined;
  alt?: string | undefined;
  eager?: boolean;
  class?: string;
  aspectRatio?: number;
}

const imagePath = "../assets/" + Astro.props.filename ?? "placeholder-hero.jpg";

const images = import.meta.glob<ImageMetadata>("../assets/*", {
  import: "default",
});

const imagesrc = await images[imagePath]?.();

const image = imagesrc ? await getImage({ src: imagesrc, alt: "" }) : undefined;
---

{
  imagesrc && (
    <Picture
      loading={Astro.props.eager ? "eager" : "lazy"}
      widths={[360, 720]}
      width={+(image?.width ?? 0)}
      height={+(image?.height ?? 0)}
      aspectRatio={Astro.props.aspectRatio}
      src={imagesrc}
      alt={Astro.props.alt ?? ""}
      class={Astro.props.class}
    />
  )
}

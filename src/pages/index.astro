---
import BaseLayout from "../layouts/BaseLayout.astro";
import BasePicture from "../components/BasePicture.astro";
import { mdiBriefcase, mdiController, mdiNewspaper } from "@mdi/js";
import Icon from "../components/Icon.astro";
import { CONSTS } from "../consts";
---

<BaseLayout>
  <div class="flex flex-col md:flex-row items-center gap-4 my-4">
    <div>
      <h2>Welcome!</h2>
      <p>
        I am passionate about crafting innovative products from the ground up,
        leveraging my experience in
        <strong>engineering, management, and business</strong>.
      </p>
      <p>
        I bring a fresh vision and drive rapid progression at the early stages
        of every project, using a combination of
        <strong>methodology, creativity, and a proactive attitude</strong>.
      </p>
      <p>Let me give you a tour!</p>
    </div>
    <div class="max-w-xs">
      <BasePicture filename="avatar.jpg" eager class="rounded-full" />
    </div>
  </div>

  <hr />

  <h2>
    <Icon path={mdiBriefcase} />
    <span>Freelancing CTO</span>
  </h2>
  <p></p>
  <h2>
    <a href={CONSTS.urls.freelance}>More information</a>
  </h2>

  <hr />

  <h2>
    <Icon path={mdiController} />
    <span>Scree - The game</span>
  </h2>
  <p></p>
  <h2>
    <a href={CONSTS.urls.scree}>
      <span>Watch the trailer</span>
    </a>
  </h2>

  <hr />

  <h2>
    <Icon path={mdiNewspaper} />
    <span>Blog</span>
  </h2>
  <h2>
    <a href={CONSTS.urls.blog}>
      <span>Read the blog</span>
    </a>
  </h2>
</BaseLayout>

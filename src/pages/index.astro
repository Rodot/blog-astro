---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  mdiBriefcase,
  mdiController,
  mdiHandPeace,
  mdiNewspaper,
} from "@mdi/js";
import { CONSTS } from "../consts";
import Banner from "../components/Banner.astro";
---

<BaseLayout class="px-4">
  <Banner title="Welcome!" icon={mdiHandPeace} image="avatar.jpg">
    I'm curious, high-energy & quick learner, so I ended up touching many
    different things. Let me show you around!
  </Banner>

  <Banner
    title="Freelance CTO"
    icon={mdiBriefcase}
    image="hero-freelance.jpg"
    cta="Skills & portfolio"
    url={CONSTS.urls.freelance}
  >
    I am passionate about crafting innovative products from the ground up,
    leveraging my experience in engineering, management, and business.
  </Banner>

  <Banner
    title="Scree"
    icon={mdiController}
    image="hero-scree.png"
    cta="Watch the trailer"
    url={CONSTS.urls.scree}
  >
    Scree is a roguelike shooter in a physics sandbox. Discover creative ways to
    fight through swarms of hostiles to go as far as you can.
  </Banner>

  <Banner
    title="Blog"
    icon={mdiNewspaper}
    image="hero-blog.jpg"
    cta="Latest updates"
    url={CONSTS.urls.blog}
  >
    Photography, engineering and business.
  </Banner>
</BaseLayout>
